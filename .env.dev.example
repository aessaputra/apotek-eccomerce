# Env variables
ENV=development
API_URL=https://your-api-url.com

# EXPO
EXPO_SLUG=apotek-ecommerce
# Set your Tailscale IP untuk remote development
# Dapatkan IP dengan: tailscale ip -4
# Contoh: REACT_NATIVE_PACKAGER_HOSTNAME=100.x.x.x
# Biarkan kosong untuk auto-detect
REACT_NATIVE_PACKAGER_HOSTNAME=
EXPO_NAME="DEV - Apotek Ecommerce"
EXPO_PROJECT_ID=c0810e0b-d165-4d8f-b295-33059503bb63
EXPO_IOS_BUNDLE_IDENTIFIER=com.apotekecommerce.dev
EXPO_ANDROID_PACKAGE=com.apotekecommerce.dev

# Google Maps (Maps SDK for Android/iOS is free — no billing charges for map display)
GOOGLE_MAPS_API_KEY=

# Google Places API New (v1) - for address autocomplete
# Get from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Required APIs: Places API (New), Geocoding API
EXPO_PUBLIC_GOOGLE_API_KEY=

# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=
