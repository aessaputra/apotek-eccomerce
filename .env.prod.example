# Env variables
ENV=production
API_URL=https://your-api-url.com

# EXPO
EXPO_SLUG=apotek-ecommerce
EXPO_NAME="Apotek Ecommerce"
EXPO_PROJECT_ID=e6d087ad-de06-41af-8018-b6641e43d3d2
EXPO_IOS_BUNDLE_IDENTIFIER=com.apotekecommerce
EXPO_ANDROID_PACKAGE=com.apotekecommerce

# Google Maps (Maps SDK for Android/iOS is free — no billing charges for map display)
GOOGLE_MAPS_API_KEY=

# Google Places API New (v1) - for address autocomplete
# Get from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Required APIs: Places API (New), Geocoding API
EXPO_PUBLIC_GOOGLE_API_KEY=

# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=
