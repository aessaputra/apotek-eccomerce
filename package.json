{
  "name": "apotek-eccomerce",
  "main": "expo-router/entry",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start -c",
    "dev:ios": "cross-env EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start --ios -c",
    "dev:android": "cross-env EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start --android -c",
    "dev:web": "cross-env EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start --web -c",
    "dev:tailscale": "cross-env EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo start -c",
    "dev:doctor": "cross-env EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- npx expo-doctor",
    "dev:secret:push": "dotenvx run -f .env.dev -- eas secret:push --scope project --env-file .env.dev --force",
    "dev:secret:list": "dotenvx run -f .env.dev -- eas env:list",
    "dev:build:mobile": "npm run dev:secret:push && cross-env EXPO_NO_DOTENV=1 dotenv -e .env.dev -- npx eas build --profile development",
    "dev:build:web": "dotenvx run -f .env.dev -- npx expo export --platform web",
    "dev:serve:web": "dotenvx run -f .env.dev -- npx expo serve",
    "dev:deploy:web": "npm run dev:build:web && dotenvx run -f .env.dev -- eas deploy --environment development",
    "dev:config:public": "dotenvx run -f .env.dev -- npx expo config --type public",
    "lint": "expo lint",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "test": "jest --verbose --passWithNoTests",
    "test:watch": "jest --verbose --passWithNoTests --watch",
    "prepare": "husky",
    "android": "cross-env EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo run:android",
    "ios": "cross-env EXPO_NO_DOTENV=1 dotenvx run -f .env.dev -- expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "^5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/drawer": "^7.1.1",
    "@react-navigation/native": "^7.0.14",
    "@reduxjs/toolkit": "^2.5.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tamagui/config": "1.144.3",
    "@tamagui/lucide-icons": "^1.144.3",
    "@tamagui/portal": "^1.144.3",
    "aes-js": "^3.1.2",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.8",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-maps": "^1.27.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "redux-logger": "^3.0.6",
    "tamagui": "1.144.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@dotenvx/dotenvx": "^1.33.0",
    "@tamagui/babel-plugin": "1.144.3",
    "@tamagui/metro-plugin": "^1.144.3",
    "@testing-library/react-native": "^13.0.1",
    "@types/aes-js": "^3.1.4",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^18.3.0",
    "@types/redux-logger": "^3.0.13",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "eslint": "^9.32.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.17",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "react-test-renderer": "^19.1.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-maps"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
